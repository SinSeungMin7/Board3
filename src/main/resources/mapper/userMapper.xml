<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <!-- 만약 주소줄이 에러일시 -->
  <!-- 
  Windows -> Preferences -> 검색 : xml 
  -> Xml(Wild Web Developer) -> 오른쪽 탭에서
  체크 Download ML Resource ....
  
  namespace="com.green.user.mapper.UserMapper" : interface 위치
   -->

<!-- namespace="com.green.users.mapper.MenuMapper" : interface 위치 -->
<mapper namespace="com.green.users.mapper.UserMapper">
	<!-- 메뉴 목록 조회 -->
	<select id="getMenuList"
	        resultType="com.green.users.dto.UserDTO">
			
	 SELECT    MENU_ID, MENU_NAME, MENU_SEQ
	 FROM      MENUS
	 ORDER BY  MENU_SEQ ASC 
	 	
	</select>
	

</mapper>
